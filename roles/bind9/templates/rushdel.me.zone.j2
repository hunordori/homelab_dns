; {{ ansible_managed }}
;
; Forward zone file for rushdel.me
; Serial is auto-generated from the current date/time on each Ansible run.

$TTL {{ dns_ttl }}

$ORIGIN rushdel.me.

@               IN      SOA     ns1.rushdel.me.  {{ dns_admin_email }}. (
                                {{ ansible_facts['date_time']['year'] }}{{ ansible_facts['date_time']['month'] }}{{ ansible_facts['date_time']['day'] }}{{ ansible_facts['date_time']['hour'] }}   ; serial (YYYYMMDDhh)
                                {{ dns_soa_refresh }}             ; refresh
                                {{ dns_soa_retry }}             ; retry
                                {{ dns_soa_expire }}              ; expire
                                {{ dns_soa_minimum }}              ; minimum TTL
                                )

; --- Nameserver records ---
{% for ns in dns_nameservers %}
                IN      NS      {{ ns.name }}.rushdel.me.
{% endfor %}

; --- Nameserver A records (glue) ---
{% for ns in dns_nameservers %}
{{ "%-30s" | format(ns.name) }}IN      A       {{ ns.ip }}
{% endfor %}

; --- VIP record (HA DNS entry point) ---
{{ "%-30s" | format("dns") }}IN      A       {{ dns_vip }}

; --- Subdomain delegation: home.rushdel.me ---
{% for ns in dns_nameservers %}
home              IN      NS      {{ ns.name }}.rushdel.me.
{% endfor %}

; --- Subdomain delegation: gitlab.rushdel.me ---
{% for ns in dns_nameservers %}
gitlab            IN      NS      {{ ns.name }}.rushdel.me.
{% endfor %}

; --- A records ---
{% for record in dns_a_records %}
{% if record.comment is defined %}
{{ "%-30s" | format(record.name) }}IN      A       {{ record.ip }}    ; {{ record.comment }}
{% else %}
{{ "%-30s" | format(record.name) }}IN      A       {{ record.ip }}
{% endif %}
{% endfor %}

; --- CNAME records ---
{% for record in dns_cname_records %}
{% if record.comment is defined %}
{{ "%-30s" | format(record.name) }}IN      CNAME   {{ record.target }}.rushdel.me.    ; {{ record.comment }}
{% else %}
{{ "%-30s" | format(record.name) }}IN      CNAME   {{ record.target }}.rushdel.me.
{% endif %}
{% endfor %}
