// {{ ansible_managed }}
//
// Zone declarations for rushdel.me DNS infrastructure.
// Role: {{ bind9_role }}

// Include the TSIG key for zone transfer authentication
include "/etc/bind/tsig-key.conf";

{% if bind9_role == "master" %}
// =============================================================================
// MASTER configuration
// Zones are served from local zone files. Secondaries pull via AXFR/IXFR.
// =============================================================================

{% for zone_name, zone_config in dns_zones.items() %}
zone "{{ zone_name }}" {
    type master;
    file "{{ bind9_zone_dir }}/{{ zone_name }}.zone";
    allow-transfer { key {{ tsig_key_name }}; };
    also-notify {
{% for ns in dns_nameservers %}
{% if ns.ip != dns_master_ip %}
        {{ ns.ip }};
{% endif %}
{% endfor %}
    };
};

{% endfor %}
{% elif bind9_role == "secondary" %}
// =============================================================================
// SECONDARY configuration
// Zones are pulled from the master via authenticated zone transfers (TSIG).
// =============================================================================

// Server statement to associate the TSIG key with the master
server {{ dns_master_ip }} {
    keys { {{ tsig_key_name }}; };
};

{% for zone_name, zone_config in dns_zones.items() %}
zone "{{ zone_name }}" {
    type slave;
    file "{{ bind9_zone_dir }}/{{ zone_name }}.zone";
    masters { {{ dns_master_ip }}; };
};

{% endfor %}
{% endif %}
